//  |   __|  _  |   __|_   _|   __|   __|_   _|     |  |  |
//  |   __|     |__   | | | |   __|   __| | | |   --|     |
//  |__|  |__|__|_____| |_| |__|  |_____| |_| |_____|__|__|  GROUPS + HYPR IMAGE
//
//  groups.jsonc layout'u + hypr.png + TÜM satırlarda MDI iconlar.

{
    "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
    "logo": {
        "source": "/home/x/.local/share/fastfetch/images/hypr.png",
        "type": "kitty-direct",
        "width": 36,
        "height": 25,
        "preserveAspectRatio": true,
        "padding": {
            "top": 1,
            "left": 3,
            "right": 5,
            "bottom": 5
        }
    },
    "display": {
        "separator": " ➜  "
    },
    "modules": [
        "break",
        "break",
        "break",
        "break",
        "break",
        "break",
        {
            "type": "os",
            "key": "󰣇  OS   ",
            "keyColor": "31",
        },
        {
            "type": "kernel",
            "key": " ┌ 󰌽 ",
            "keyColor": "31",
        },
        {
            "type": "packages",
            "format": "{} (pacman)",
            "key": " ├ 󰏖 ",
            "keyColor": "31",
        },
        {
            "type": "shell",
            "key": " └ 󰆍 ",
            "keyColor": "31",
        },
        "break",
        {
            "type": "wm",
            "key": "󰍺  WM   ",
            "keyColor": "32",
        },
        {
            "type": "cursor",
            "key": " ┌ 󰳽 ",
            "keyColor": "32",
        },
        {
            "type": "terminal",
            "key": " └ 󰆍 ",
            "keyColor": "32",
        },
        "break",
        {
            "type": "cpu",
            "format": "{1} ({3}) @ {7} GHz",
            "key": " ┌ 󰻠 ",
            "keyColor": "33",
        },
        {
            "type": "gpu",
            "format": "{1} {2} @ {12} GHz",
            "key": " ├ 󰢮 ",
            "keyColor": "33",
        },
        {
            "type": "memory",
            "key": " ├ 󰍛 ",
            "keyColor": "33",
        },
        {
            "type": "swap",
            "key": " ├ 󰓡 ",
            "keyColor": "33",
        },
        {
            "type": "disk",
            "key": " └ 󰋊 ",
            "keyColor": "33",
        },

        "break",
    ]
}
